        font-size: 0.9rem;
        white-space: nowrap;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(255, 196, 0, 0.3);
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        pointer-events: none;
        z-index: 10;
      }
      .floating-tooltip::after {
        content: "";
        position: absolute;
        top: 100%;
        right: 24px;
        border-width: 8px;
        border-style: solid;
        border-color: rgba(255, 196, 0, 0.9) transparent transparent transparent;
