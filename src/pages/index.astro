      /* パペットコンテナ全体 */
      .monkey-puppet-container {
        position: relative;
        flex: 1;
        max-width: 100%;
        margin-right: -4rem; /* テキストとの間隔調整 */
        will-change: transform;
        transform-style: preserve-3d;
      }

      /* 胴体 */
      .monkey-body {
        width: 100%;
        height: auto;
        display: block;
        position: relative; 
        z-index: 2; /* 脚より手前に表示 */
      }

      /* 2本の脚をまとめるラッパー */
      .monkey-legs-wrapper {
        position: absolute; 
        z-index: 1; /* 胴体の奥（背後）に表示 */
        
        /* topの数値を大きくして位置を下げる */
        top: 90%;  
        left: 23%; 
        width: 20%; 
        
        display: flex;
        justify-content: space-between;
      }

      /* 各脚の共通スタイル */
      .monkey-leg {
        width: 45%; 
        height: auto;
        transform-origin: 50% 5%; 
        /* 3.5sから1.8sに短縮し、ゆらゆら感を強調 */
        animation: swingMonkeyLeg 1.8s ease-in-out infinite alternate;
        transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94); 
        will-change: transform;
        transform: perspective(1000px) rotateX(0deg); 
      }

      /* 右足専用：タイミングと支点を少しずらす */
      .monkey-leg.leg-right {
        /* アニメーションの高速化に合わせてディレイも調整 */
        animation-delay: -0.8s; 
        transform-origin: 50% 2%;
      }

      /* 振り子アニメーション */
      @keyframes swingMonkeyLeg {
        /* 揺れ幅を少し大きくして視認性を高める (-5deg〜10deg -> -8deg〜12deg) */
        0% { transform: rotate(-8deg); } 
        100% { transform: rotate(12deg); }
      }

      /* --- ここから追加：ホバー時の処理 --- */
      
      /* 足にマウスが近づいた際（JSでクラス付与）、
         JSのtransform計算と干渉しないようCSSアニメーションを完全に無効化する */
      .monkey-leg.is-repelling {
        animation: none !important;
      }
      
