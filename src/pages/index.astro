        }
        /* スクロールバーを非表示にしてスッキリさせる */
        .gallery-track::-webkit-scrollbar {
          display: none;
        }
        .animal-card {
          scroll-snap-align: center;
        }

        /* 4. オーダーセクションとの接続を滑らかに */
        section.order-section {
          padding-top: 5rem !important;
          padding-bottom: 6rem !important;
          margin-top: -40px !important; /* 0 から -40px へ修正 */
        }

        /* プロフィールセクションの被りを追加 */
        .profile-section {
          margin-top: -40px !important;
        }
        
        /* 5. 見出しと段落の左端を完全に揃える（過去のパディング指定を強制リセット） */
        h1, h2, h3, p {
          padding-left: 0 !important;
          padding-right: 0 !important;
        }
        .hero-text-container,
        .concept-text,
        .gallery-header {
          padding-left: 1.5rem !important;
          padding-right: 1.5rem !important;
        }
      }

      /* スワイプヒント（基本はPC向けに非表示） */
      .swipe-hint-mobile {
        display: none; 
      }

      /* スマホ表示時の上書き設定（必ず基本設定より後に記述する） */
      @media (max-width: 768px) {
        .swipe-hint-mobile {
          display: flex; 
          align-items: center;
          gap: 0.5rem;
          margin-top: 1.5rem;
          color: var(--accent-green);
          font-size: 0.85rem;
          font-weight: 700;
          letter-spacing: 0.1em;
          animation: swipePointerAnim 2s infinite ease-in-out;
        }
        .swipe-hint-mobile svg {
          fill: currentColor;
        }
        @keyframes swipePointerAnim {
          0%, 100% { transform: translateX(0); }
          50% { transform: translateX(10px); }
        }
      }

      /* ==========================================
         サイトフッター
      ========================================== */
      .site-footer {
        background-color: var(--text-color); /* ダークな背景 */
        color: rgba(255, 255, 255, 0.7);
        padding: 3rem 2rem 2rem;
        position: relative;
        z-index: 20;
      }

      .footer-content {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .legal-notice h4 {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        color: rgba(255, 255, 255, 0.5);
        text-transform: uppercase;
        margin-bottom: 0.8rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }

      .legal-notice p {
        font-size: 0.78rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.55);
        margin-bottom: 0.5rem;
      }

      .copyright {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.3);
        text-align: center;
        letter-spacing: 0.05em;
        padding-top: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        margin: 0;
      }

      /* 売り切れバッジ */
      .sold-out-badge {
        position: absolute;
        top: -15px; /* カードの外側にはみ出させる。文字数増に対応して少し上に */
        left: -15px;
        background-color: #e74c3c; /* 赤系 */
        color: #ffffff;
        font-size: 0.65rem; /* 文字数増に対応してわずかに小さく */
        font-weight: 700;
        padding: 0.4em 1em; /* 横長の文字に合わせた余白調整 */
        border-radius: 20px;
        z-index: 5; /* 画像の上に表示 */
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        letter-spacing: 0.05em;
        white-space: nowrap; /* 改行を防ぐ */
      }

      /* 部屋に飾ったイメージ画像のパネル */
      .room-view-card {
        background: #ffffff;
        padding: 1.2rem;
        border-radius: 12px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        width: 320px; /* 横幅をポスターサイズに凝縮 */
        height: auto; /* 100%からautoに変更し、下部の無駄な空白を完全消去 */
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        position: relative;
      }
      /* PC環境ではアイコンを完全に非表示にする */
      .swipe-indicator-right {
        display: none;
      }
      .room-view-img {
        width: 100%;
        height: 400px; /* 縦の長さを強調 */
        object-fit: cover;
        border-radius: 8px;
      }
      .room-view-text {
        padding: 1.2rem 1rem 0.2rem; /* 上(1.5->1.2)と下(0.5->0.2)の余白を詰め、間延びを解消 */
        text-align: center;
      }
      .room-view-text p {
        font-family: inherit;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        line-height: 1.5; /* 1.8から縮小して2行時の間延びを抑える */
        color: var(--accent-green);
        margin: 0;
      }

      /* スマホ表示時の調整（既存のメディアクエリ内を上書き） */
      @media (max-width: 768px) {
        .room-view-card {
          width: 280px; /* モバイルでも縦長感を維持 */
          scroll-snap-align: center;
        }
        .room-view-img {
          height: 380px; /* スマホでも高さを確保 */
        }
        .room-view-text p {
          font-size: 0.9rem;
        }

        /* スマホ環境でのみアイコンを表示し、カード右横に配置 */
        .swipe-indicator-right {
          display: flex;
          position: absolute;
          right: -1.2rem; /* カードの外側、gapの空間に配置 */
          top: 50%;
          transform: translateY(-50%);
          width: 36px;
          height: 36px;
          background: var(--accent-green);
          color: #fff;
          border-radius: 50%;
          justify-content: center;
          align-items: center;
          box-shadow: 0 4px 10px rgba(0,0,0,0.15);
          z-index: 10;
          animation: swipeRightBounce 1.5s infinite;
        }
        
        .swipe-indicator-right svg {
          width: 20px;
          height: 20px;
          margin-left: 2px; /* 矢印を視覚的に中央に寄せる */
        }

        @keyframes swipeRightBounce {
          0%, 100% { transform: translateY(-50%) translateX(0); }
          50% { transform: translateY(-50%) translateX(6px); }
        }
      }

      /* ==========================================
         キャンバスサイズ・アニメーション
      ========================================== */
      .canvas-size-section {
        background-color: #ffffff;
        padding-bottom: 8rem;
        position: relative;
        z-index: 15;
      }
      .canvas-anim-wrapper {
        perspective: 1000px; /* 立体感を出すための視点距離 */
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 4rem 0 6rem; /* 寸法線が表示される余白を確保 */
        position: relative; /* 丸の絶対配置の基準にするため追加 */
      }

      .canvas-3d-box {
        position: relative;
        width: 220px;
        height: 273px;
        transform-style: preserve-3d;
        /* アニメーション開始時：下からポップアップ（影なし） */
        opacity: 0;
        transform: rotateY(-45deg) rotateX(10deg) translateY(50px) scale(0.8);
        box-shadow: none;
      }

      /* アニメーション（ intersection-observer用） --- */
      .canvas-size-section.is-visible .canvas-3d-box {
        animation: boxAppear 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      }

      @keyframes boxAppear {
        to {
          opacity: 1;
          transform: rotateY(-45deg) rotateX(10deg) translateY(0) scale(1);
          box-shadow: -10px 15px 30px rgba(0,0,0,0.1); /* 影を追加 */
        }
      }

      /* 表面パネル（影を消す） */
      .c-front {
        position: absolute;
        width: 100%;
        height: 100%;
        background-color: #fcfcfc;
        border: 2px solid #e0e0e0;
        border-right: none; /* 側面と結合するため右ボーダーなし */
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 3rem;
        color: #eeeeee;
        font-weight: 700;
        box-shadow: none; /* 表面自体の影を削除 */
        transform: translateZ(15px);
      }

      /* 1. 厚みの側面を擬似要素で表面の右端に完全に密着させる（離れて見えないように） --- */
      .c-front::after {
        content: '';
        position: absolute;
        top: -2px; /* ボーダー分調整 */
        bottom: -2px; /* ボーダー分調整 */
        right: -15px; /* 厚み分 */
        width: 15px; /* 厚み分 */
        background-color: #e8e8e8;
        border: 2px solid #e0e0e0;
        border-left: none; /* 表面と結合するため左ボーダーなし */
        /* 手前を軸に奥へ回転 */
        transform-origin: left;
        transform: rotateY(90deg);
      }

      /* 各寸法線の共通設定 */
      .dim-line-y,
      .dim-line-x {
        position: absolute;
        background-color: var(--accent-green);
        opacity: 0;
      }

      .dim-text-y,
      .dim-text-x {
        position: absolute;
        color: var(--accent-green);
        font-family: inherit;
        font-weight: 700;
        font-size: 1.05rem;
        opacity: 0;
        white-space: nowrap;
        letter-spacing: 0.05em;
        transform: scale(0);
      }

      /* アニメーション時 */
      .canvas-size-section.is-visible .dim-line-y,
      .canvas-size-section.is-visible .dim-line-x {
        opacity: 1;
      }

      /* Y軸（縦）寸法線 */
      .dim-line-y {
        left: -30px;
        top: 0;
        width: 2px;
        height: 0; /* アニメーション用 */
        transform: translateZ(15px);
      }
      .dim-line-y::before,
      .dim-line-y::after {
        content: '';
        position: absolute;
        left: -4px;
        width: 10px;
        height: 2px;
        background: inherit;
      }
      .dim-line-y::before { top: 0; }
      .dim-line-y::after { bottom: 0; }

      .dim-text-y {
        left: -120px;
        top: 50%;
        transform: translateY(-50%) scale(0) translateZ(15px);
      }

      /* X軸（横）寸法線 */
      .dim-line-x {
        bottom: -30px;
        left: 0;
        height: 2px;
        width: 0; /* アニメーション用 */
        transform: translateZ(15px);
      }
      .dim-line-x::before,
      .dim-line-x::after {
        content: '';
        position: absolute;
        top: -4px;
        width: 2px;
        height: 10px;
        background: inherit;
      }
      .dim-line-x::before { left: 0; }
      .dim-line-x::after { right: 0; }

      .dim-text-x {
        bottom: -65px;
        left: 50%;
        transform: translateX(-50%) scale(0) translateZ(15px);
      }

      /* 厚み表示（丸デザイン） */
      .depth-circle {
        position: absolute;
        right: 15%; /* 右側に配置 */
        top: 50%;
        transform: translateY(-50%) scale(0);
        width: 85px;
        height: 85px;
        background-color: rgba(0, 163, 129, 0.1); /* 薄い緑 */
        border: 2px solid var(--accent-green);
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        color: var(--accent-green);
        font-family: inherit;
        font-weight: 700;
        font-size: 0.85rem;
        line-height: 1.4;
        letter-spacing: 0.05em;
        opacity: 0;
        z-index: 10;
      }

      .canvas-size-section.is-visible .depth-circle {
        /* 縦・横の寸法が出た後、最後にポコッと現れる */
        animation: popCircle 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards 2.2s;
      }

      @keyframes popCircle {
        to { opacity: 1; transform: translateY(-50%) scale(1); }
      }

      /* Y軸（縦）寸法線 */
      .canvas-size-section.is-visible .dim-line-y {
        animation: drawY 0.4s ease forwards 0.8s;
      }
      .canvas-size-section.is-visible .dim-text-y {
        animation: popText 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards 1.1s;
      }

      @keyframes drawY { to { height: 100%; } }

      /* X軸（横）寸法線 */
      .canvas-size-section.is-visible .dim-line-x {
        animation: drawX 0.4s ease forwards 1.5s;
      }
      .canvas-size-section.is-visible .dim-text-x {
        animation: popTextX 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards 1.8s;
      }

      @keyframes drawX { to { width: 100%; } }
      @keyframes popTextX { to { opacity: 1; transform: translateX(-50%) scale(1) translateZ(15px); } }

      /* X/Yテキストポップ（共通化） */
      @keyframes popText { to { opacity: 1; transform: translateY(-50%) scale(1) translateZ(15px); } }
      @media (max-width: 768px) {
        .canvas-size-section {
          padding-bottom: 4rem;
        }
        .canvas-3d-box {
          transform: rotateY(-15deg) rotateX(5deg) translateY(30px) scale(0.75);
        }
        @keyframes boxAppear {
          to { opacity: 1; transform: rotateY(-15deg) rotateX(5deg) translateY(0) scale(0.85); }
        }
        .dim-text-y { left: -90px; font-size: 0.9rem; }
        .dim-text-x { bottom: -50px; font-size: 0.9rem; }
        /* スマホ表示時の丸の位置・サイズ調整 */
        .depth-circle {
          right: 5%;
          width: 70px;
          height: 70px;
          font-size: 0.75rem;
        }
      }

      /* --- 暗闇モード スイッチ（ピル型UI・中央配置版） --- */
      .dark-mode-switch {
        position: relative;
        margin: 0 auto; /* 上マージンをゼロにして直下に配置 */
        z-index: 200;
        pointer-events: auto; /* 親のhero-text-containerがpointer-events:noneのため必須 */
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(0,0,0,0.08);
        padding: 0.8rem 1.5rem;
        border-radius: 30px;
        cursor: pointer;
        color: #333;
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }
      
      /* 暗闇モード時のボタンデザイン反転と視線誘導アニメーション */
      :global(body.is-dark) .dark-mode-switch {
        background: rgba(30, 30, 30, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        animation: pillGlowPop 4s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite;
      }

      @keyframes pillGlowPop {
        0%, 85%, 100% {
          transform: scale(1) translateY(0);
          box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }
        90% {
          transform: scale(1.08) translateY(-4px);
          box-shadow: 0 0 20px rgba(255, 255, 255, 0.6), 0 4px 15px rgba(0,0,0,0.3);
        }
        95% {
          transform: scale(1.02) translateY(-1px);
          box-shadow: 0 0 10px rgba(255, 255, 255, 0.3), 0 4px 15px rgba(0,0,0,0.3);
        }
      }
      
      .dark-mode-switch:hover {
        transform: scale(1.05) translateY(-2px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
      }

      /* ホバー時はアニメーションを強制停止し、ホバースタイルを優先 */
      :global(body.is-dark) .dark-mode-switch:hover {
        animation: none !important;
        box-shadow: 0 6px 20px rgba(255, 255, 255, 0.15);
      }

      .dark-mode-switch svg {
        width: 20px;
        height: 20px;
        display: block;
      }

      .switch-text {
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        white-space: nowrap;
      }

      /* モード切替に伴うテキストとアイコンの表示・非表示ロジック */
      .icon-moon, .text-dark-mode { display: none; }
      .icon-sun, .text-light-mode { display: block; }
      
      :global(body.is-dark) .icon-sun,
      :global(body.is-dark) .text-light-mode { display: none !important; }
      :global(body.is-dark) .icon-moon,
      :global(body.is-dark) .text-dark-mode { display: block !important; }
      
      @media (max-width: 768px) {
        .dark-mode-switch {
          margin: 0 auto;
          padding: 0.6rem 1.2rem;
        }
        .switch-text { font-size: 0.8rem; }
        .dark-mode-switch svg { width: 18px; height: 18px; }
      }
      
      /* 注: これ以前にあった body:not(.is-dark) .hero-animal-wrapper:hover 関連のブロックは完全に削除しました */

      /* --- 暗闇への遷移 --- */
      body { transition: background-color 0.8s ease, color 0.8s ease; }
      body.is-dark {
        --bg-color: #0d1115; /* 漆黒に近い紺 */
        --text-color: #e0e0e0;
      }
      
      /* --- 追加：暗闇モードをヒーローエリアのみに限定 --- */
      body.is-dark section:not(.hero) {
        /* ヒーロー以降のセクションは元の明るい色を強制維持して上書き */
        --bg-color: #faf8f5;
        --text-color: #333333;
        background-color: var(--bg-color);
        color: var(--text-color);
      }

      /* --- アニマルの多層レイヤー構造（最終修正版・CSSスコープ問題対応） --- */
      /* JSで生成されるレイヤーにはAstroのスコープ属性が付与されないため、:global()を使用 */
      :global(.hero-animal-silhouette), :global(.hero-animal-eyes) {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background-size: contain; background-repeat: no-repeat; background-position: center;
        transition: opacity 0.5s ease;
        border-radius: 0;
        pointer-events: none;
      }
      
      :global(.hero-animal-silhouette) {
        filter: brightness(0);
        opacity: 0;
        z-index: 1;
      }
      
      :global(.hero-animal-eyes) {
        opacity: 0;
        z-index: 2;
        filter: drop-shadow(0 0 12px rgba(255, 230, 0, 0.9)) drop-shadow(0 0 4px rgba(255, 255, 255, 0.8));
        /* 画像背景が黒だった場合の防御策：明るい目の色だけを抽出して合成する */
        mix-blend-mode: screen;
      }

      /* 元画像（一番上） */
      .hero-animal {
        /* 親のサイズを維持するため相対配置にし、必ず100%で広げる */
        position: relative;
        width: 100%; height: 100%;
        z-index: 3;
      }

      /* --- 暗闇時の振る舞い --- */
      /* JSで動的生成したレイヤーにはAstroスコープが付与されないため、状態変化も :global() で囲む必要があります */
      :global(body.is-dark .hero-animal-silhouette) { opacity: 1; }
      :global(body.is-dark .hero-animal-eyes) {
        opacity: 1;
        /* 不気味なランダム瞬き */
        animation: blinkAnim 6s infinite;
      }
      
      @keyframes blinkAnim {
        0%, 96%, 98%, 100% { opacity: 1; }
        97%, 99% { opacity: 0; } /* 一瞬だけ消える */
      }

      /* 懐中電灯（スポットライト）効果 */
      /* .hero-animalは静的HTMLなのでそのままスコープが効きますが、body.is-darkはグローバル要素なので分けて指定します */
      :global(body.is-dark) .hero-animal {
        /* JSで更新される変数座標を中心に、半径80pxの円形に切り抜く */
        -webkit-mask-image: radial-gradient(circle 80px at var(--light-x, -100px) var(--light-y, -100px), black 0%, transparent 100%);
        mask-image: radial-gradient(circle 80px at var(--light-x, -100px) var(--light-y, -100px), black 0%, transparent 100%);
      }

      /* SVGロゴの滑らかな色遷移 */
      .hero-title-svg g[mask] path {
        transition: fill 0.8s ease, stroke 0.8s ease;
      }
      
      /* 暗闇モード時はSVGのパスをダークモード用のテキスト色（白系）で上書きする */
      :global(body.is-dark) .hero-title-svg g[mask] path {
        fill: var(--text-color) !important;
        stroke: var(--text-color) !important;
      }

      /* 固定UI（ロゴ・ナビゲーション）のすりガラス背景をダークモード用に反転 */
      :global(body.is-dark) .site-logo {
        background-color: rgba(30, 30, 30, 0.65) !important;
      }
      :global(body.is-dark) .side-nav {
        background-color: rgba(30, 30, 30, 0.85) !important;
      }

      /* 著作権セクションの背景色とテキスト色をダークモード用に反転 */
      :global(body.is-dark) .site-footer {
        background-color: #1a1a1a !important;
      }
      :global(body.is-dark) .site-footer .legal-notice h4,
      :global(body.is-dark) .site-footer .legal-notice p,
      :global(body.is-dark) .site-footer .copyright {
        color: #eeeeee !important;
      }

      @media (max-width: 768px) {
        /* スマホは指で画面が隠れるため、懐中電灯の光の半径を120pxへ拡大し、さらに指の上の領域が見えるように中心を上にずらす(Y座標 - 90px) */
        :global(body.is-dark) .hero-animal {
          -webkit-mask-image: radial-gradient(circle 120px at var(--light-x, -100px) calc(var(--light-y, -100px) - 90px), black 0%, transparent 100%) !important;
          mask-image: radial-gradient(circle 120px at var(--light-x, -100px) calc(var(--light-y, -100px) - 90px), black 0%, transparent 100%) !important;
        }
      }

      /* --- PC環境で縦幅が狭い場合のギャラリー自動縮小（見切れ防止） --- */
      @media (min-width: 769px) and (max-height: 850px) {
        .gallery-sticky-container {
          justify-content: center; /* 上揃えを解除し、画面の中央に配置 */
          padding-top: 0;
        }
        .gallery-header {
          margin-bottom: 3vh; /* 見出しとカードの隙間を圧縮 */
        }
        .gallery-header .section-title {
          font-size: clamp(1.8rem, 4vw, 2.5rem) !important;
        }
        .gallery-header p {
          font-size: 0.95rem !important;
          line-height: 1.6 !important;
          margin-top: 0.5rem !important;
        }
        .gallery-track {
          gap: 3rem; /* カード間の隙間を圧縮 */
        }
        .animal-card {
          width: 32vh; /* ビューポートの高さ(vh)に連動してカード全体を縮小 */
          padding: 1rem;
        }
        .animal-card-inner {
          margin-bottom: 1rem;
        }
        .room-view-card {
          width: 38vh;
        }
        .room-view-img {
          height: 45vh;
        }
        .gallery-contact-card {
          width: 32vh;
          padding: 2rem 1.5rem;
        }
      }

      /* --- ポストカードセット セクション --- */
      .postcard-section {
        background-color: #faf8f5;
        padding-bottom: 8rem;
        position: relative;
        z-index: 18; /* canvas-size(15)より上でprofile(20)の下 */
      }
      .postcard-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 4rem;
        max-width: 1000px;
        margin: 0 auto;
      }
      .postcard-image {
        flex: 1;
        max-width: 500px;
      }
      .postcard-image img {
        width: 100%;
        height: auto;
        border-radius: 16px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        display: block;
      }
      .postcard-info {
        flex: 1;
      }
      .postcard-spec-box {
        display: inline-block;
        border: 1px solid var(--accent-green);
        background-color: rgba(0, 163, 129, 0.05);
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        color: var(--accent-green);
        font-size: 0.85rem;
        font-weight: 500;
        margin-top: 0;
        line-height: 1.4;
      }
      .postcard-description {
        font-size: 0.95rem; /* PC版を少し小さく */
        line-height: 1.8;
        margin-top: 1.5rem;
        color: #555555;
      }
      .postcard-price {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--accent-green);
        margin-bottom: 2.5rem;
        letter-spacing: 0.05em;
      }
      .instagram-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
      }
      .instagram-btn .instagram-icon {
        width: 20px;
        height: 20px;
        fill: currentColor;
      }
      @media (max-width: 768px) {
        .postcard-section {
          padding-bottom: 5rem;
        }
        .postcard-content {
          flex-direction: column;
          gap: 2.5rem;
          text-align: center;
        }
        .postcard-image {
          margin: 0 auto;
        }
        .postcard-info .section-title {
          text-align: center;
        }
        .postcard-spec-box {
          margin: 0 auto;
          display: inline-block;
        }
        .postcard-description {
          font-size: 0.95rem;
          text-align: left;
        }
      }
    </style>
  </head>
