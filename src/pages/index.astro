          margin-bottom: 1.5rem !important;
          width: 100% !important;
          box-sizing: border-box;
        }
        .gallery-track {
          transform: none !important; 
          width: 100% !important; 
          padding: 1rem 1.5rem 2rem 1.5rem !important; 
          overflow-x: auto !important; /* トラック自体はスクロール可能にする */
          scroll-snap-type: x mandatory; 
