---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet">
    <title>アニマルの庭</title>
    <style>
      :root {
        --bg-color: #faf8f5; /* ごく薄いオフホワイトに変更 */
        --text-color: #333333;
        --accent-green: #00A381;
        --accent-yellow: #FFC400;
        --eye-bg: #ffffff;
        --eye-pupil: #2c2c2c;
      }
      body {
        margin: 0;
        font-family: "a-otf-koburina-gothic-pr6n", "Koburina Gothic", "Zen Kaku Gothic New", "Hiragino Sans", "ヒラギノ角ゴ ProN", "Yu Gothic", sans-serif;
        background-color: var(--bg-color);
        color: var(--text-color);
        line-height: 1.8;
        letter-spacing: 0.05em;
        overflow-x: hidden; /* 画面全体の意図しない横揺れを防止 */
      }
      h1, h2, h3 {
        font-family: "a-otf-koburina-gothic-pr6n", "Koburina Gothic", "Zen Kaku Gothic New", "Hiragino Sans", "ヒラギノ角ゴ ProN", "Yu Gothic", sans-serif;
        font-weight: 500;
      }
      .section-title {
        font-family: "a-otf-koburina-gothic-pr6n", "Koburina Gothic", "Zen Kaku Gothic New", "Hiragino Sans", "ヒラギノ角ゴ ProN", "Yu Gothic", sans-serif;
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 700;
        letter-spacing: 0.1em;
        margin-bottom: 2rem;
        line-height: 1.4;
      }
      .hamburger {
        display: none;
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        z-index: 2000; /* ナビゲーション(1000)より前面に配置して「×」を見せる */
        background: transparent;
        border: none;
        cursor: pointer;
        width: 40px;
        height: 40px;
        padding: 0;
      }

      .hamburger span {
        display: block;
        position: absolute; /* 位置を固定してモーフィングしやすくする */
        left: 0;
        width: 100%;
        height: 2px;
        background-color: var(--text-color);
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
      }

      /* 通常時の3本線の位置（等間隔に配置） */
      .hamburger span:nth-child(1) { top: 10px; }
      .hamburger span:nth-child(2) { top: 20px; }
      .hamburger span:nth-child(3) { top: 30px; }

      /* メニューが開いている時（is-openクラス時）のバツ印アニメーション */
      .hamburger.is-open span:nth-child(1) {
        transform: translateY(10px) rotate(45deg);
      }

      .hamburger.is-open span:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
      }

      .hamburger.is-open span:nth-child(3) {
        transform: translateY(-10px) rotate(-45deg);
      }

      @media (max-width: 768px) {
        .hamburger.is-open span {
          background-color: var(--text-color);
        }
      }
      .side-nav {
        position: fixed;
        top: 2rem;
        right: 2.5rem;
        z-index: 1000; /* 十分に高いz-indexを設定して、すべての背景装飾の上に表示 */
        width: max-content;
        transition: right 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.4s ease;
        /* すりガラス効果 */
        padding: 2rem 1.5rem; /* テキストとの間隔を調整 */
        background-color: rgba(252, 252, 252, 0.85); /* 背景色を少し濃くして、テキストを際立たせる */
        backdrop-filter: blur(12px); /* ぼかし効果を强めて、背景の円の影響を減らす */
        -webkit-backdrop-filter: blur(12px);
        border-radius: 20px;
      }
      .side-nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: row-reverse;
        gap: 1.8rem;
      }
      .side-nav a {
        color: var(--text-color);
        text-decoration: none;
        font-family: "a-otf-koburina-gothic-pr6n", "Koburina Gothic", "Zen Kaku Gothic New", "Hiragino Sans", "ヒラギノ角ゴ ProN", "Yu Gothic", sans-serif;
        font-weight: 500;
        font-size: 0.99rem; /* 元の1.1remから90%に縮小 */
        letter-spacing: 0.3em;
        writing-mode: vertical-rl;
        text-orientation: mixed;
        display: inline-block;
        transition: color 0.2s, opacity 0.2s, transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        text-shadow: none; /* 安っぽい影を消去 */
      }
      .side-nav a:hover {
        color: var(--accent-green);
        opacity: 1;
        transform: translateX(-8px) scale(1.05);
      }
      
      @media (max-width: 768px) {
        .hamburger {
          display: block;
        }
        .side-nav {
          position: fixed;
          top: 0;
          right: -100%;
          width: 280px;
          height: 100vh;
          background-color: rgba(252, 252, 252, 0.85);
          backdrop-filter: blur(12px);
          -webkit-backdrop-filter: blur(12px);
          display: flex;
          align-items: flex-start;
          justify-content: flex-start;
          padding: 6rem 2rem 2rem;
          box-shadow: -4px 0 15px rgba(0,0,0,0.05);
          transition: right 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }
        .side-nav.is-open {
          right: 0;
        }
        .side-nav ul {
          text-align: left;
          display: flex;
          flex-direction: column;
          gap: 2rem;
          width: 100%;
        }
        .side-nav a {
          writing-mode: horizontal-tb;
          font-size: 1.08rem; /* 元の1.2remから90%に縮小 */
          letter-spacing: 0.1em;
          display: block;
          border-bottom: 1px solid rgba(0,0,0,0.05);
          padding-bottom: 1rem;
        }
        .hamburger.is-open span:nth-child(1) { transform: translateY(10px) rotate(45deg); }
        .hamburger.is-open span:nth-child(2) { opacity: 0; }
        .hamburger.is-open span:nth-child(3) { transform: translateY(-10px) rotate(-45deg); }
        .side-nav a:hover {
          transform: translateY(-4px) scale(1.02);
        }
      }
      .section-container {
        padding: 0 2rem; /* 上下に設定されていた無駄な 4rem を削除し、間延びを根絶 */
        max-width: 1000px;
        margin: 0 auto;
      }
      .hero {
        position: sticky;
        top: 0;
        width: 100%;
        height: 100vh;
        min-height: 600px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background-color: transparent; /* 背景色を透明にして背後のCanvasを見せる */
        z-index: 1;
        will-change: opacity, filter; /* スクロール時の描画負荷を軽減し、滑らかに変化させる */
      }

      .hero-text-container {
        position: relative;
        z-index: 30; /* 10から30へ変更し、前景の動物(z-index:20)より前面に出す */
        text-align: center;
        pointer-events: none;
      }

      .eyes-container { margin-bottom: 2rem; }
      .hero h1 { display: flex; justify-content: center; align-items: center; margin-bottom: 1.5rem; }
      
      /* 展開したSVGの基本設定 */
      .hero-title-svg {
        max-width: 100%;
        width: 420px;
        height: auto;
        pointer-events: auto;
        transform-origin: center;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      .hero-title-svg:hover {
        transform: scale(1.06) rotate(-2deg);
        cursor: pointer;
      }
      
      @media (max-width: 768px) {
        .hero-title-svg { width: 280px; }
      }

      /* マスク用パスのアニメーション（JSで取得した正確な長さを適用） */
      .draw-path {
        stroke-dasharray: var(--path-length, 1000); 
        stroke-dashoffset: var(--path-length, 1000);
        animation: drawLine 0.3s ease-out forwards;
      }

      @keyframes drawLine {
        to { stroke-dashoffset: 0; }
      }

      /* 書き順と速度の完全制御（全体の時間を1/2に短縮） */

      /* 「見」：1画ずつ丁寧に */
      .draw-path.path-1 { animation-delay: 0.05s; animation-duration: 0.2s; }
      .draw-path.path-2 { animation-delay: 0.15s; animation-duration: 0.2s; }
      .draw-path.path-3 { animation-delay: 0.25s; animation-duration: 0.2s; }
      .draw-path.path-4 { animation-delay: 0.35s; animation-duration: 0.2s; }
      .draw-path.path-5 { animation-delay: 0.45s; animation-duration: 0.2s; }
      .draw-path.path-6 { animation-delay: 0.55s; animation-duration: 0.2s; }
      .draw-path.path-7 { animation-delay: 0.65s; animation-duration: 0.25s; }
      
      /* 「つ」：1画で長い線を引く */
      .draw-path.path-8 { animation-delay: 0.85s; animation-duration: 0.45s; }
      
      /* 「め」 */
      .draw-path.path-9 { animation-delay: 1.25s; animation-duration: 0.25s;}
      .draw-path.path-10 { animation-delay: 1.4s; animation-duration: 0.5s; }
      
      /* 「る」：最後のハネまで粘る */
      .draw-path.path-11 { animation-delay: 1.85s; animation-duration: 0.55s; }
      
      /* --- ここで一呼吸（完全なタメ） --- */

      /* 「アニマル」：新しい気持ちで書き出す */
      .draw-path.path-12 { animation-delay: 2.65s; animation-duration: 0.35s; } 
      .draw-path.path-13 { animation-delay: 2.9s; animation-duration: 0.4s; }
      
      /* 「ニ」 */
      .draw-path.path-14 { animation-delay: 3.2s; animation-duration: 0.2s; }
      .draw-path.path-15 { animation-delay: 3.3s; animation-duration: 0.2s; }
      .draw-path.path-16 { animation-delay: 3.45s; animation-duration: 0.35s; }
      
      /* 「マ」 */
      .draw-path.path-17 { animation-delay: 3.7s; animation-duration: 0.2s; }
      .draw-path.path-18 { animation-delay: 3.85s; animation-duration: 0.4s; }
      
      /* 「ル」 */
      .draw-path.path-19 { animation-delay: 4.15s; animation-duration: 0.45s; }

      .hero p { font-size: clamp(0.9rem, 1.5vw, 1.1rem); color: var(--text-color); margin-bottom: 2.5rem; max-width: 600px; line-height: 1.8; margin-left: auto; margin-right: auto; }

      /* マイクロコピー（操作のヒント） */
      .interaction-hint {
        font-size: 0.75rem !important; /* 他のテキストより明確に小さくする */
        color: #888888 !important; /* 薄いグレーにして背景に馴染ませる */
        letter-spacing: 0.15em;
        margin-top: 1rem;
        /* ゆっくりと明滅させて視線を誘導する */
        animation: pulseHint 3s ease-in-out infinite alternate;
        pointer-events: none; /* テキスト自体が邪魔にならないようにする */
      }

      @keyframes pulseHint {
        0% { opacity: 0.3; }
        100% { opacity: 0.8; }
      }


      .hero-animal-wrapper {
        position: absolute;
        opacity: 0;
        z-index: 1;
        /* 座標の基準点を要素の左上から中心に補正する */
        transform: translate(-50%, -50%);
        transform-origin: center center;
      }

      /* JSで準備が完了した要素だけフェードインさせる */
      .hero-animal-wrapper.is-ready {
        animation: gatherAnim 1.5s cubic-bezier(0.175, 0.885, 0.32, 1.1) forwards;
      }

      .hero-animal {
        background-color: transparent;
        border-radius: 0;
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
        transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        will-change: transform;
      }


      /* 後景（奥・小さめ・少しボケる） */
      .depth-bg { z-index: 2; width: 100px; height: 100px; }
      .depth-bg .hero-animal {
        filter: blur(3px);
        opacity: 0.8;
      }

      /* 中景（ピントが合う・標準サイズ） */
      .depth-mg { z-index: 8; width: 180px; height: 180px; }
      .depth-mg .hero-animal {
        filter: blur(0);
      }

      /* 前景（手前・大迫力・強くボケる） */
      .depth-fg { z-index: 20; width: 400px; height: 400px; pointer-events: none; }
      .depth-fg .hero-animal {
        filter: blur(8px);
        pointer-events: auto;
      }

      @keyframes gatherAnim {
        0% {
          opacity: 0;
          /* 中心補正(-50%)を維持しつつスタート位置を適用 */
          transform: translate(calc(-50% + var(--start-x, 0px)), calc(-50% + var(--start-y, 0px))) scale(0.8);
        }
        100% {
          opacity: 1;
          /* 完了時も中心補正(-50%, -50%)を維持する（0, 0 で上書き消去しない！） */
          transform: translate(-50%, -50%) scale(1);
        }
      }

      @media (max-width: 768px) {
        .depth-bg { width: 70px; height: 70px; }
        .depth-mg { width: 120px; height: 120px; }
        .depth-fg { width: 220px; height: 220px; }
        .depth-bg .hero-animal { filter: blur(2px); }
        .depth-fg .hero-animal { filter: blur(4px); }
        .hero-title-svg { width: 280px; }

        /* スマホでのスクロール描画負荷を軽減するため、重い filter(blur) 効果を無効化 */
        .depth-bg .hero-animal,
        .depth-mg .hero-animal,
        .depth-fg .hero-animal {
          filter: none !important;
        }
        .hero {
          will-change: opacity, transform; /* filterを削除 */
        }

        /* スマホは指で画面が隠れるため、懐中電灯の光の半径を80pxから120pxへ拡大する */
        :global(body.is-dark) .hero-animal {
          -webkit-mask-image: radial-gradient(circle 120px at var(--light-x, -100px) var(--light-y, -100px), black 0%, transparent 100%) !important;
          mask-image: radial-gradient(circle 120px at var(--light-x, -100px) var(--light-y, -100px), black 0%, transparent 100%) !important;
        }
      }
      .order-section {
        background-color: #e9edc9;
        border-radius: 16px;
        padding: 3rem 2rem;
        text-align: center;
        margin-bottom: 4rem;
      }
      .step-ui {
        margin-top: 2rem;
        padding: 2rem;
        background: rgba(255,255,255,0.6);
        border-radius: 12px;
      }
      .btn {
        display: inline-block;
        background-color: var(--accent-green);
        color: #fff;
        padding: 1rem 2rem;
        border-radius: 30px;
        text-decoration: none;
        font-family: inherit;
        font-weight: 700;
        transition: transform 0.2s, background-color 0.2s, box-shadow 0.2s;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        box-shadow: 0 4px 10px rgba(0, 163, 129, 0.2);
      }
      .btn:hover {
        background-color: var(--accent-yellow);
        color: #333;
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(255, 196, 0, 0.3);
      }
      .gallery-wrapper {
        height: 450vh !important; /* 18点に合わせてスクロール距離を延長 */
        position: relative;
        background-color: #f7f7f7;
        padding-bottom: 20vh;
      }

      .gallery-sticky-container {
        position: sticky;
        top: 0;
        width: 100%;
        height: 100vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        padding-top: 2vh; /* 6vhからさらに限界まで縮小 */
        background-color: transparent;
      }

      .gallery-header {
        position: relative;
        top: auto;
        left: auto;
        z-index: 10;
        width: 100%;
        padding: 0 5vw;
        margin-bottom: 5vh; /* 作品群との間隔 */
        pointer-events: none;
      }

      .gallery-track {
        display: flex;
        gap: 6rem;
        padding: 0 50vw;
        width: max-content;
        will-change: transform;
        align-items: center;
      }

      /* ギャラリー展示風のカードデザイン */
      .animal-card {
        background: #ffffff;
        padding: 1.2rem 1.2rem 1.6rem;
        text-align: center;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08), 0 5px 15px rgba(0,0,0,0.03);
        width: 240px;
        flex-shrink: 0;
        transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        position: relative; /* バッジ配置の基準にするため追加 */
        overflow: visible !important; /* バッジのはみ出しを切らないようにする */
      }

      /* カード全体をまとめるコンテナ（旧：.animal-card-link） */
      .animal-card-content {
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      /* イラストとオーバーレイを囲むコンテナ */
      .animal-card-inner {
        position: relative;
        width: 100%;
        aspect-ratio: 1/1;
        border-radius: 8px;
        margin-bottom: 1.5rem; /* 作品名との間隔 */
        overflow: hidden; /* オーバーレイのはみ出し防止 */
      }

      /* イラスト */
      .animal-img {
        width: 100%;
        height: 100%; /* コンテナいっぱいに広げる */
        background: #f0f0f0;
        border-radius: 0; /* 親コンテナで管理 */
        margin-bottom: 0; /* 親コンテナで管理 */
        /* キャンバスの質感をダミーで追加 */
        background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.1) 0px, rgba(255,255,255,0.1) 2px, transparent 2px, transparent 4px);
        /* ホバー時の色変化用の transition */
