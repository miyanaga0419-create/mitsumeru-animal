        overflow: visible;
      }
      .floating-tooltip {
        position: absolute;
        bottom: calc(100% + 15px);
        right: 0;
        transform-origin: bottom right;
        transform: scale(0);
        background-color: rgba(255, 196, 0, 0.9);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        color: #333;
        padding: 0.8rem 1.2rem;
