    <script>
      // ページ更新時に必ずトップ（ヒーローエリア）に戻るように設定
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      window.scrollTo(0, 0);

      // タイトルロゴの各パスの正確な長さを計算し、CSS変数にセットする
      document.addEventListener('DOMContentLoaded', () => {
        const drawPaths = document.querySelectorAll('.draw-path');
        drawPaths.forEach(path => {
          const length = path.getTotalLength();
          path.style.setProperty('--path-length', length);
        });
      });

      const animalWrappers = document.querySelectorAll('.hero-animal-wrapper');
      const heroSection = document.getElementById('hero-area');

      let isMobileDevice = window.innerWidth <= 768;
      let currentMouseX = typeof window !== 'undefined' ? window.innerWidth / 2 : 0;
      let currentMouseY = typeof window !== 'undefined' ? window.innerHeight / 2 : 0;
      let currentScrollProgress = 0;

      // 安全な固定均等配置処理
      const initRandomAnimals = () => {
        const images = [1, 2, 3, 4, 5, 6, 7].sort(() => Math.random() - 0.5);
        const depths = [
          { cls: 'depth-fg', z: 2.8 }, { cls: 'depth-fg', z: 2.0 },
          { cls: 'depth-mg', z: 1.2 }, { cls: 'depth-mg', z: 1.0 }, { cls: 'depth-mg', z: 0.8 },
          { cls: 'depth-bg', z: 0.5 }, { cls: 'depth-bg', z: 0.3 }
        ].sort(() => Math.random() - 0.5);

        const numAnimals = animalWrappers.length;

        animalWrappers.forEach((wrapper, index) => {
          const animal = wrapper.querySelector('.hero-animal');
          
          // シルエットと光る目のレイヤーを動的に生成して追加
          let silhouette = wrapper.querySelector('.hero-animal-silhouette');
          let eyes = wrapper.querySelector('.hero-animal-eyes');
          if (!silhouette) {
            silhouette = document.createElement('div');
            silhouette.className = 'hero-animal-silhouette';
            wrapper.insertBefore(silhouette, animal);
          }
          if (!eyes) {
            eyes = document.createElement('div');
            eyes.className = 'hero-animal-eyes';
            wrapper.insertBefore(eyes, animal);
          }

          const imgNum = images[index];
          const normalImg = `url('/hero-animal-0${imgNum}.webp')`;
          const eyesImg = `url('/hero-animal-0${imgNum}-eyes.webp')`; // 目の画像(.webp)

          animal.style.backgroundImage = normalImg;
          silhouette.style.backgroundImage = normalImg; // シルエットも元画像を黒く塗りつぶす
          eyes.style.backgroundImage = eyesImg;
          
          wrapper.className = 'hero-animal-wrapper ' + depths[index].cls;
          wrapper.dataset.depth = depths[index].z;

          // 1. 角度計算：真上(-90度)を起点に完全に均等分割（ランダム排除）
          const baseAngle = (360 / numAnimals) * index - 90;
          const radian = baseAngle * (Math.PI / 180);

          // 2. 距離計算：スマホとPCで固定の半径比率を設定
          let radiusX, radiusY;
          if (isMobileDevice) {
            // スマホ：左右の広がりを30%、上下を40%で固定（はみ出さない）
            radiusX = 30; 
            radiusY = 40;
          } else {
            // PC：左右40%、上下35%で固定
            radiusX = 40;
            radiusY = 35;
          }

          // 中心位置(50%)に設定
          wrapper.style.left = `calc(50% + ${Math.cos(radian) * radiusX}%)`;
          wrapper.style.top = `calc(50% + ${Math.sin(radian) * radiusY}%)`;

          wrapper.style.setProperty('--start-x', `${Math.cos(radian) * -100}px`);
          wrapper.style.setProperty('--start-y', `${Math.sin(radian) * -100}px`);
          wrapper.dataset.dirX = Math.cos(radian);
          wrapper.dataset.dirY = Math.sin(radian);

          wrapper.classList.add('is-ready');
        });
      };

      initRandomAnimals();

      window.addEventListener('resize', () => {
        isMobileDevice = window.innerWidth <= 768;
      });

      // 座標の更新処理（二重の中心補正バグを修正）
      const updateAnimalPositions = () => {
        animalWrappers.forEach(wrapper => {
          const animal = wrapper.querySelector('.hero-animal');
          const silhouette = wrapper.querySelector('.hero-animal-silhouette');
          const eyes = wrapper.querySelector('.hero-animal-eyes');
          
          if (!animal) return;
          
          const depth = parseFloat(wrapper.dataset.depth || 1);
          const dirX = parseFloat(wrapper.dataset.dirX);
          const dirY = parseFloat(wrapper.dataset.dirY);
          
          let transformStr = '';

          if (isMobileDevice) {
            // モバイル用の移動計算（-50%の二重補正を削除）
            const maxSpread = 150 * depth; 
            const scrollMoveX = dirX * maxSpread * currentScrollProgress;
            const scrollMoveY = dirY * maxSpread * currentScrollProgress;
            transformStr = `translate(${scrollMoveX}px, ${scrollMoveY}px)`;
          } else {
            // PC用の移動・回転計算（-50%の二重補正を削除）
            const rect = wrapper.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            
            const deltaX = currentMouseX - centerX;
            const deltaY = currentMouseY - centerY;
            const mouseMoveX = deltaX * 0.02 * depth;
            const mouseMoveY = deltaY * 0.02 * depth;
            
            const maxAngle = 25;
            let rotateY = deltaX * 0.04;
            let rotateX = -deltaY * 0.04;
            rotateY = Math.max(-maxAngle, Math.min(maxAngle, rotateY));
            rotateX = Math.max(-maxAngle, Math.min(maxAngle, rotateX));

            const maxSpread = 400 * depth;
            const scrollMoveX = dirX * maxSpread * currentScrollProgress;
            const scrollMoveY = dirY * maxSpread * currentScrollProgress;
            
            transformStr = `translate(${mouseMoveX + scrollMoveX}px, ${mouseMoveY + scrollMoveY}px) perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
          }

          animal.style.transform = transformStr;
          if (silhouette) silhouette.style.transform = transformStr;
          if (eyes) eyes.style.transform = transformStr;
        });
      };

      // マウス移動イベント（PCのみ実行し、スマホでのスワイプ誤爆による負荷を防ぐ）
      if (!isMobileDevice) {
        document.addEventListener('mousemove', (e) => {
          currentMouseX = e.clientX;
          currentMouseY = e.clientY;

          document.querySelectorAll('.monkey-leg').forEach(leg => {
            const rect = leg.getBoundingClientRect();
            const legBottomX = rect.left + rect.width / 2;
            const legBottomY = rect.bottom;
            
            const deltaX = currentMouseX - legBottomX;
            const deltaY = currentMouseY - legBottomY;
            const distance = Math.sqrt(deltaX * deltaX + deltaY * deltaY);

            const magneticRange = 200; 

            if (distance > magneticRange) {
              leg.style.transform = ''; 
              leg.classList.remove('is-repelling');
              return;
            }

            leg.classList.add('is-repelling');
            const force = (magneticRange - distance) / magneticRange;
            const maxAngle = 40; 
            const direction = deltaX > 0 ? -1 : 1;
            const rotateZ = direction * maxAngle * force;

            leg.style.transformOrigin = '50% 5%';
            leg.style.transform = `perspective(1000px) rotate(${rotateZ}deg)`;
          });

          if (currentScrollProgress < 1) {
            updateAnimalPositions();
          }
        });
      }

      // スクロールイベント：フェードアウトと拡散処理を同時に実行
      window.addEventListener('scroll', () => {
        if (!heroSection) return;

        const scrollY = window.scrollY;
        const windowHeight = window.innerHeight;
        const fadeEndPosition = windowHeight * 0.6; 
        
        if (scrollY <= fadeEndPosition) {
          currentScrollProgress = scrollY / fadeEndPosition;
          
          const currentOpacity = 1 - currentScrollProgress;
          heroSection.style.opacity = currentOpacity;
          
          // モバイルでは blur アニメーションを省略
          if (!isMobileDevice) {
            const currentBlur = currentScrollProgress * 10;
            heroSection.style.filter = `blur(${currentBlur}px)`;
          } else {
            heroSection.style.filter = 'none';
          }
          
          updateAnimalPositions();
        } else if (currentScrollProgress !== 1) {
          currentScrollProgress = 1;
          heroSection.style.opacity = 0;
          if (!isMobileDevice) {
            heroSection.style.filter = `blur(10px)`;
          }
          updateAnimalPositions();
        }
      }, { passive: true });

      const pupils = document.querySelectorAll('.pupil');
      const heroArea = document.getElementById('hero-area');

      heroArea.addEventListener('mousemove', (e) => {
        pupils.forEach(pupil => {
          const rect = pupil.getBoundingClientRect();
          const x = rect.left + rect.width / 2;
          const y = rect.top + rect.height / 2;
          const radian = Math.atan2(e.clientY - y, e.clientX - x);
          const distance = 15; 
          const moveX = Math.cos(radian) * distance;
          const moveY = Math.sin(radian) * distance;
          pupil.style.transform = `translate(${moveX}px, ${moveY}px)`;
        });
      });

      heroArea.addEventListener('mouseleave', () => {
        pupils.forEach(pupil => {
          pupil.style.transform = `translate(0px, 0px)`;
        });
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });

      document.querySelectorAll('.fade-in-up').forEach(el => {
        observer.observe(el);
      });

      // Hamburger menu toggle
      const hamburger = document.getElementById('hamburger');
      const sideNav = document.getElementById('side-nav');

      if (hamburger && sideNav) {
        hamburger.addEventListener('click', () => {
          hamburger.classList.toggle('is-open');
          sideNav.classList.toggle('is-open');
        });

        document.querySelectorAll('.side-nav a').forEach(link => {
          link.addEventListener('click', () => {
            hamburger.classList.remove('is-open');
            sideNav.classList.remove('is-open');
          });
        });
      }


      let lastScrollY = window.scrollY;
      // .dark-mode-switch をリストに追加し、スクロール時に一緒に消す
      const hideableElements = document.querySelectorAll('.side-nav, .hamburger, .site-logo, .dark-mode-switch');

      window.addEventListener('scroll', () => {
        const currentScrollY = window.scrollY;
        // 下スクロール かつ ページ上部から100px以上離れている場合
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
          hideableElements.forEach(el => el.classList.add('nav-hidden'));
        } else {
          // 上スクロール または ページ最上部付近
          hideableElements.forEach(el => el.classList.remove('nav-hidden'));
        }
        lastScrollY = currentScrollY;
      }, { passive: true });

      const galleryWrapper = document.querySelector('.gallery-wrapper');
      const galleryTrack = document.getElementById('gallery-track');

      window.addEventListener('scroll', () => {
        if (!galleryWrapper || !galleryTrack) return;

        const wrapperRect = galleryWrapper.getBoundingClientRect();
        const wrapperTop = wrapperRect.top; 
        const wrapperHeight = galleryWrapper.offsetHeight;
        const windowHeight = window.innerHeight;

        if (wrapperTop <= 0 && wrapperTop > -(wrapperHeight - windowHeight)) {
          // 画面に固定された瞬間から、遊び（ディレイ）なしで横スクロールを開始
          const scrolled = Math.abs(wrapperTop);
          const effectiveScrollHeight = wrapperHeight - windowHeight;
          
          let progress = scrolled / effectiveScrollHeight;
          progress = Math.min(progress, 1); // 1.0を超えないように制限
          
          const maxScroll = galleryTrack.scrollWidth - window.innerWidth;
          galleryTrack.style.transform = `translateX(-${progress * maxScroll}px)`;
        } else if (wrapperTop > 0) {
          galleryTrack.style.transform = `translateX(0px)`;
        } else if (wrapperTop <= -(wrapperHeight - windowHeight)) {
          // 完全にスクロールしきった後は最後の位置で固定
          const maxScroll = galleryTrack.scrollWidth - window.innerWidth;
          galleryTrack.style.transform = `translateX(-${maxScroll}px)`;
        }
      }, { passive: true });


      // --- 暗闇スイッチと懐中電灯ロジック ---
      const darkModeSwitch = document.getElementById('dark-mode-switch');
      if (darkModeSwitch) {
        darkModeSwitch.addEventListener('click', () => {
          document.body.classList.toggle('is-dark');
        });
      }

      // 懐中電灯（スポットライト）の座標を各アニマルに渡す
      const updateSpotlight = (clientX, clientY) => {
        if (!document.body.classList.contains('is-dark')) return;
        
        animalWrappers.forEach(wrapper => {
          const animal = wrapper.querySelector('.hero-animal');
          if (!animal) return;
          const rect = animal.getBoundingClientRect();
          // アニマル要素内の相対座標を計算
          const x = clientX - rect.left;
          const y = clientY - rect.top;
          
          animal.style.setProperty('--light-x', `${x}px`);
          animal.style.setProperty('--light-y', `${y}px`);
        });
      };

      if (heroSection) {
        // PC用のマウスイベント
        heroSection.addEventListener('mousemove', (e) => updateSpotlight(e.clientX, e.clientY), { passive: true });
        
        const hideSpotlight = () => updateSpotlight(-1000, -1000);
        heroSection.addEventListener('mouseleave', hideSpotlight);

        // --- スマホ用の高度な操作切り分け（長押しでスクロールロック） ---
        let touchTimer;
        let isSearching = false;

        heroSection.addEventListener('touchstart', (e) => {
          if (!document.body.classList.contains('is-dark')) return;
          isSearching = false;
          // 画面に触れて150ミリ秒指を止めると「探索モード」に入りスクロールをロックする
          touchTimer = setTimeout(() => { isSearching = true; }, 150);
          updateSpotlight(e.touches[0].clientX, e.touches[0].clientY);
        }, { passive: false }); // e.preventDefault() を使うため passive: false に変更

        heroSection.addEventListener('touchmove', (e) => {
          if (!document.body.classList.contains('is-dark')) return;
          
          if (isSearching) {
            // 探索モード中：画面スクロールを強制停止し、指に光を追従させる
            e.preventDefault(); 
          } else {
            // すぐにスワイプした場合：タイマーを解除し、画面の上下スクロールを優先する
            clearTimeout(touchTimer); 
          }
          updateSpotlight(e.touches[0].clientX, e.touches[0].clientY);
        }, { passive: false });

        heroSection.addEventListener('touchend', () => {
          clearTimeout(touchTimer);
          isSearching = false;
          hideSpotlight();
        });
      }
    </script>
